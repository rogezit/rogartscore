{
    "configurations": [
        {
            "name": "ESP32 (Arduino)",
            "includePath": [
                "${workspaceFolder}/**",
                "${env:HOME}/Library/Arduino15/packages/esp32/hardware/esp32/3.3.7/cores/esp32",
                "${env:HOME}/Library/Arduino15/packages/esp32/hardware/esp32/3.3.7/variants/doitESP32devkitV1",
                "${env:HOME}/Library/Arduino15/packages/esp32/hardware/esp32/3.3.7/libraries/**/src",
                "${env:HOME}/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/include/**",
                "${env:HOME}/Library/Arduino15/packages/esp32/tools/esp32-libs/3.3.7/dio_qspi/include",
                "${env:HOME}/Library/Arduino15/packages/esp32/tools/esp-x32/2511/xtensa-esp-elf/include/**",
                "${env:HOME}/Library/Arduino15/packages/esp32/tools/esp-x32/2511/lib/gcc/xtensa-esp-elf/14.2.0/include"
            ],
            "defines": [
                "ARDUINO=10819",
                "ESP32=1",
                "ESP_PLATFORM",
                "ARDUINO_ESP32_DEV",
                "ARDUINO_ARCH_ESP32",
                "ARDUINO_BOARD=\"ESP32_DEV\"",
                "F_CPU=240000000L",
                "__cplusplus=201103L"
            ],
            "compilerPath": "${env:HOME}/Library/Arduino15/packages/esp32/tools/esp-x32/2511/bin/xtensa-esp-elf-g++",
            "cStandard": "c11",
            "cppStandard": "c++17",
            "intelliSenseMode": "gcc-x86",
            "forcedInclude": [
                "${env:HOME}/Library/Arduino15/packages/esp32/hardware/esp32/3.3.7/cores/esp32/Arduino.h"
            ]
        }
    ],
    "version": 4
}
